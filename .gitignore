# ============================================
# Atelier — project-level .gitignore
# ============================================

# --- Secrets — NEVER commit ---
.env
.env.local
**/.dev.vars
**/.dev.vars.local

# --- Python ---
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/

# --- Node ---
node_modules/
**/node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Cloudflare Wrangler ---
.wrangler/
**/.wrangler/

# --- IDE / editor files ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Build artifacts ---
dist/
build/

# --- Test outputs (generated images we don't need in repo) ---
test_output.png
test_output.jpg
**/test_sketch.png
**/test_sketch.jpg
live_test.jpg

# --- Streamlit (reference Python) ---
.streamlit/secrets.toml

# --- Generated sketches folder (if you start saving locally) ---
generated/
